# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- E2E tests ---
PLAYWRIGHT_BASE_URL=https://mailpilot-virid.vercel.app

# --- AI (pick one — Gemini is free tier; Anthropic is paid) ---
# Selection priority: Gemini wins if both are set.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Persistence (Supabase — recommended for production) ---
# Without these the store falls back to in-memory (volatile across cold starts).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- At-rest encryption (required when SUPABASE_URL is set) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MAILPILOT_ENCRYPTION_KEY=

# --- Gmail (per-mailbox OAuth) ---
# Setup: console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web).
# Redirect: https://<host>/api/oauth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Microsoft Graph (per-mailbox OAuth) ---
# Setup: entra.microsoft.com → App registrations → Web platform.
# Redirect: https://<host>/api/oauth/graph/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT=common
